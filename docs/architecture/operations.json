{
  "version": "1.0",
  "description": "Machine-readable operation contracts for the Miners platform. Each operation defines a deterministic code path from UI action to DB write. Read by Claude and test_ui_spec.py to answer debugging questions without grepping source files.",
  "note": "dag.json is the module import graph. This file is the data-flow and operation contract layer.",

  "ssot": {
    "read_priority": [
      {
        "rank": 1,
        "table": "data_points",
        "condition": "extraction_method IN ('analyst_edited','manual','analyst_gap','review_approved','review_edited')",
        "authority": "analyst-touched — write-guarded from pipeline overwrite"
      },
      {
        "rank": 2,
        "table": "data_points",
        "condition": "pipeline auto-accepted (regex + LLM agreed within threshold)",
        "authority": "pipeline"
      },
      {
        "rank": 3,
        "table": "review_queue",
        "condition": "status = 'pending'",
        "authority": "unresolved — not yet a canonical value"
      },
      {
        "rank": 4,
        "table": null,
        "condition": "no row exists",
        "authority": "gap — period not covered"
      }
    ],
    "write_guard": {
      "protected_methods": ["analyst", "analyst_approved", "analyst_edited", "manual", "review_approved", "review_edited"],
      "field": "extraction_method",
      "enforced_in": "src/routes/explorer.py:explorer_cell_save",
      "rule": "Pipeline extraction never overwrites rows where extraction_method is in protected_methods. Analyst edits write to data_points with extraction_method='analyst_edited'."
    }
  },

  "pipeline_stages": [
    {
      "id": "ingest",
      "name": "Ingest",
      "description": "Fetch raw documents and store text. No extraction.",
      "writes": ["reports", "asset_manifest"],
      "reads": [],
      "gate": null,
      "spec_ids": ["2.1", "2.1.4"],
      "files": [
        "src/scrapers/ir_scraper.py",
        "src/scrapers/edgar_connector.py",
        "src/scrapers/archive_ingestor.py"
      ]
    },
    {
      "id": "parse",
      "name": "Parse",
      "description": "Split documents into chunks for extraction.",
      "writes": ["document_chunks"],
      "reads": ["reports"],
      "gate": "reports.extraction_status != 'done'",
      "spec_ids": [],
      "files": [
        "src/parsers/document_parser.py",
        "src/parsers/press_release_parser.py",
        "src/parsers/annual_report_parser.py"
      ]
    },
    {
      "id": "extract",
      "name": "Extract (regex + LLM)",
      "description": "Run regex and LLM extraction in parallel per metric.",
      "writes": [],
      "reads": ["reports", "document_chunks"],
      "gate": "reports.extraction_status != 'done' OR force_reextract=True",
      "spec_ids": ["3.1.1"],
      "files": [
        "src/interpreters/regex_interpreter.py",
        "src/interpreters/llm_interpreter.py",
        "src/interpreters/interpret_pipeline.py"
      ]
    },
    {
      "id": "agree",
      "name": "Agreement",
      "description": "Compare regex and LLM outputs. Route to data_points or review_queue.",
      "writes": ["data_points", "review_queue"],
      "reads": [],
      "gate": "both extractors have run",
      "spec_ids": [],
      "files": ["src/interpreters/agreement.py", "src/interpreters/interpret_pipeline.py"]
    },
    {
      "id": "review",
      "name": "Analyst Review",
      "description": "Analyst resolves disagreements in review_queue.",
      "writes": ["data_points", "review_queue"],
      "reads": ["review_queue"],
      "gate": "analyst action required",
      "spec_ids": ["4.1.2", "R3.2"]
    },
    {
      "id": "read",
      "name": "Read Path",
      "description": "Query data_points (SSOT priority order) for UI, export, scorecard.",
      "writes": [],
      "reads": ["data_points"],
      "gate": null,
      "spec_ids": ["1.1", "DE4.2", "DE4.3", "DB6.1"]
    }
  ],

  "pipeline_edges": [
    {"from": "ingest",  "to": "parse"},
    {"from": "parse",   "to": "extract"},
    {"from": "extract", "to": "agree"},
    {"from": "agree",   "to": "data_points",   "condition": "delta <= threshold"},
    {"from": "agree",   "to": "review_queue",  "condition": "delta > threshold OR LLM-only"},
    {"from": "review",  "to": "data_points",   "condition": "analyst approves"},
    {"from": "data_points", "to": "read"}
  ],

  "operations": [
    {
      "id": "approve_review",
      "name": "Approve review item",
      "trigger": {"method": "POST", "path": "/api/review/{id}/approve"},
      "components": ["R3.4", "R3.2"],
      "dag": [
        {"step": 1, "layer": "frontend", "spec_id": "R3.4",  "action": "POST fetch /api/review/{id}/approve"},
        {"step": 2, "layer": "route",    "file": "src/routes/review.py",  "fn": "approve_review_item"},
        {"step": 3, "layer": "db_write", "file": "src/infra/db.py",       "fn": "approve_review_item", "reads": ["review_queue"], "writes": ["data_points"]},
        {"step": 4, "layer": "frontend", "spec_id": "R3.2",  "action": "remove row from review table"}
      ],
      "ssot_write": "data_points",
      "postcondition": "review_queue.status='approved'; data_points row upserted with extraction_method='review_approved'"
    },
    {
      "id": "reject_review",
      "name": "Reject review item",
      "trigger": {"method": "POST", "path": "/api/review/{id}/reject"},
      "components": ["R3.5", "R3.2"],
      "dag": [
        {"step": 1, "layer": "frontend", "spec_id": "R3.5",  "action": "POST fetch /api/review/{id}/reject"},
        {"step": 2, "layer": "route",    "file": "src/routes/review.py",  "fn": "reject_review_item"},
        {"step": 3, "layer": "db_write", "file": "src/infra/db.py",       "fn": "reject_review_item", "reads": ["review_queue"], "writes": ["review_queue"]},
        {"step": 4, "layer": "frontend", "spec_id": "R3.2",  "action": "remove row from review table"}
      ],
      "ssot_write": "review_queue",
      "postcondition": "review_queue.status='rejected'; no data_points row created"
    },
    {
      "id": "analyst_cell_save",
      "name": "Analyst edit (cell save)",
      "trigger": {"method": "POST", "path": "/api/explorer/cell/{ticker}/{period}/{metric}/save"},
      "components": ["5.1.4", "5.1.3"],
      "dag": [
        {"step": 1, "layer": "frontend", "spec_id": "5.1.4", "action": "POST fetch with edited numeric value"},
        {"step": 2, "layer": "route",    "file": "src/routes/explorer.py", "fn": "explorer_cell_save"},
        {"step": 3, "layer": "db_read",  "file": "src/infra/db.py",        "fn": "query_data_points", "reads": ["data_points"], "note": "write-guard check: reject if existing row is analyst-protected"},
        {"step": 4, "layer": "db_write", "file": "src/infra/db.py",        "fn": "insert_data_point", "writes": ["data_points"], "note": "extraction_method='analyst_edited' or 'manual'"},
        {"step": 5, "layer": "frontend", "spec_id": "5.1.3", "action": "refresh cell detail panel"}
      ],
      "ssot_write": "data_points",
      "write_guard_checked": true,
      "postcondition": "data_points row upserted with extraction_method='analyst_edited'; protected rows return 409"
    },
    {
      "id": "mark_gap",
      "name": "Mark cell as explicit gap",
      "trigger": {"method": "POST", "path": "/api/explorer/cell/{ticker}/{period}/{metric}/gap"},
      "components": ["5.1.5", "5.1.2"],
      "dag": [
        {"step": 1, "layer": "frontend", "spec_id": "5.1.5", "action": "POST fetch"},
        {"step": 2, "layer": "route",    "file": "src/routes/explorer.py", "fn": "explorer_cell_gap"},
        {"step": 3, "layer": "db_write", "file": "src/infra/db.py",        "fn": "insert_data_point", "writes": ["data_points"], "note": "extraction_method='analyst_gap', value=0.0"},
        {"step": 4, "layer": "frontend", "spec_id": "5.1.2", "action": "re-render heatmap cell as explicit gap state"}
      ],
      "ssot_write": "data_points",
      "postcondition": "data_points row with extraction_method='analyst_gap'; cell renders as explicit gap, not missing period"
    },
    {
      "id": "reextract_cell",
      "name": "Re-extract selection (regex only)",
      "trigger": {"method": "POST", "path": "/api/explorer/reextract"},
      "components": ["5.1.6", "5.1.2"],
      "dag": [
        {"step": 1, "layer": "frontend", "spec_id": "5.1.6", "action": "POST fetch with selection text + ticker + period"},
        {"step": 2, "layer": "route",    "file": "src/routes/explorer.py",              "fn": "explorer_reextract"},
        {"step": 3, "layer": "worker",   "file": "src/interpreters/interpret_pipeline.py", "fn": "extract_report", "reads": ["reports", "document_chunks"], "writes": ["data_points", "review_queue"]},
        {"step": 4, "layer": "frontend", "spec_id": "5.1.2", "action": "refresh heatmap cell"}
      ],
      "ssot_write": "data_points",
      "precondition": "write_guard checked in interpret_pipeline — analyst rows not overwritten",
      "postcondition": "data_points updated if regex matched; review_queue updated if disagreement; analyst-protected rows untouched"
    },
    {
      "id": "purge_reset",
      "name": "Purge all data (reset mode)",
      "trigger": {"method": "POST", "path": "/api/data/purge"},
      "components": ["1.2.3"],
      "dag": [
        {"step": 1, "layer": "frontend", "spec_id": "1.2.3", "action": "POST fetch with mode='reset' after confirmation gate"},
        {"step": 2, "layer": "route",    "file": "src/routes/data_points.py", "fn": "purge_data"},
        {"step": 3, "layer": "db_write", "file": "src/infra/db.py",           "fn": "purge_all",
          "writes": ["reports", "data_points", "review_queue", "scrape_queue", "asset_manifest", "document_chunks", "raw_extractions", "btc_loans", "facilities", "source_audit", "llm_benchmark_runs", "reviewed_periods"]
        },
        {"step": 4, "layer": "frontend", "spec_id": "1.2.3", "action": "reload page"}
      ],
      "ssot_write": null,
      "not_cleared": ["companies", "regime_config", "llm_prompts", "llm_ticker_hints", "metric_schema", "config_settings", "patterns", "metric_rules"],
      "postcondition": "all DATA-sourced rows deleted; CONFIG-sourced rows intact; hard_delete also clears companies+regime_config and sets auto_sync_companies_on_startup='0'; use restore_companies to repopulate"
    },
    {
      "id": "restore_companies",
      "name": "Restore companies from config",
      "trigger": {"method": "POST", "path": "/api/companies/sync/restore"},
      "components": ["1.2.1", "1.2"],
      "dag": [
        {"step": 1, "layer": "frontend", "spec_id": "1.2", "action": "POST fetch with body {confirm: true}"},
        {"step": 2, "layer": "route",    "file": "src/routes/companies.py", "fn": "restore_companies_from_config"},
        {"step": 3, "layer": "db_write", "file": "src/infra/db.py",         "fn": "sync_companies_from_config", "note": "insert_new=True — inserts all companies.json entries regardless of cleared state"},
        {"step": 4, "layer": "db_write", "file": "src/infra/db.py",         "fn": "set_config", "note": "sets auto_sync_companies_on_startup='1'"},
        {"step": 5, "layer": "frontend", "spec_id": "1.2.1", "action": "reload companies table"}
      ],
      "ssot_write": "companies",
      "postcondition": "all companies.json entries re-inserted into companies table; auto_sync_companies_on_startup restored to '1'"
    },
    {
      "id": "detect_btc_anchor",
      "name": "Detect BTC mining pivot date (EDGAR scan)",
      "trigger": {"method": "POST", "path": "/api/companies/<ticker>/detect_btc_anchor"},
      "components": ["1.2.1"],
      "dag": [
        {"step": 1, "layer": "frontend", "spec_id": "1.2.1", "action": "POST fetch; optional body {force: true} to bypass cache"},
        {"step": 2, "layer": "route",    "file": "src/routes/companies.py",         "fn": "detect_btc_anchor"},
        {"step": 3, "layer": "worker",   "file": "src/scrapers/edgar_connector.py", "fn": "detect_btc_first_filing_date", "note": "EDGAR EFTS full-text search for earliest BTC-related filing; caches result in companies.btc_first_filing_date"},
        {"step": 4, "layer": "db_write", "file": "src/infra/db.py",                 "fn": "set_btc_first_filing_date"},
        {"step": 5, "layer": "frontend", "spec_id": "1.2.1", "action": "update BTC anchor date display in company detail row"}
      ],
      "ssot_write": "companies",
      "postcondition": "companies.btc_first_filing_date set; used as floor date for EDGAR ingest and extraction gate"
    },
    {
      "id": "ingest_ir",
      "name": "Ingest IR press releases",
      "trigger": {"method": "POST", "path": "/api/ingest/ir"},
      "components": ["2.1.4"],
      "dag": [
        {"step": 1, "layer": "frontend", "spec_id": "2.1.4", "action": "POST fetch with optional auto_extract flag"},
        {"step": 2, "layer": "route",    "file": "src/routes/reports.py",       "fn": "ingest_ir"},
        {"step": 3, "layer": "worker",   "file": "src/scrapers/ir_scraper.py",   "fn": "scrape_company", "writes": ["reports"]},
        {"step": 4, "layer": "worker",   "file": "src/interpreters/interpret_pipeline.py", "fn": "extract_report",
          "condition": "auto_extract=true only",
          "writes": ["data_points", "review_queue"]
        }
      ],
      "ssot_write": "reports",
      "postcondition": "new reports rows stored; if auto_extract=true, unextracted reports run through pipeline before task marked complete"
    },
    {
      "id": "ingest_edgar",
      "name": "Ingest EDGAR filings",
      "trigger": {"method": "POST", "path": "/api/ingest/edgar"},
      "components": ["2.1"],
      "dag": [
        {"step": 1, "layer": "frontend", "spec_id": "2.1", "action": "POST fetch with optional auto_extract flag"},
        {"step": 2, "layer": "route",    "file": "src/routes/reports.py",            "fn": "ingest_edgar"},
        {"step": 3, "layer": "worker",   "file": "src/scrapers/edgar_connector.py",  "fn": "fetch_all_filings", "writes": ["reports"]},
        {"step": 4, "layer": "worker",   "file": "src/interpreters/interpret_pipeline.py", "fn": "extract_report",
          "condition": "auto_extract=true only",
          "writes": ["data_points", "review_queue"]
        }
      ],
      "ssot_write": "reports",
      "postcondition": "8-K/10-Q/10-K rows stored; accession dedup prevents double-insert; if auto_extract=true, pipeline runs before task complete"
    },
    {
      "id": "run_extraction",
      "name": "Run extraction pipeline",
      "trigger": {"method": "POST", "path": "/api/operations/interpret"},
      "components": ["3.1.1"],
      "dag": [
        {"step": 1, "layer": "frontend", "spec_id": "3.1.1", "action": "POST fetch with ticker/date-range/force_reextract"},
        {"step": 2, "layer": "route",    "file": "src/routes/operations.py",           "fn": "operations_extract"},
        {"step": 3, "layer": "worker",   "file": "src/interpreters/interpret_pipeline.py", "fn": "extract_report",
          "reads": ["reports", "document_chunks"],
          "writes": ["data_points", "review_queue"]
        }
      ],
      "ssot_write": "data_points",
      "precondition": "reports.extraction_status != 'done' (or force_reextract=True bypasses gate)",
      "postcondition": "data_points populated for auto-agrees; review_queue populated for disagreements; reports.extracted_at set"
    }
  ]
}
